{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "A product category.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the category."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the category was created."
        }
      },
      "required": ["name", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A product in the store.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "price": {
          "type": "number",
          "description": "The price of the product."
        },
        "categoryId": {
          "type": "string",
          "description": "The ID of the category this product belongs to."
        },
        "image": {
          "type": "string",
          "description": "The URL of the product image."
        },
        "description": {
          "type": "string",
          "description": "The description of the product."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the product was created."
        }
      },
      "required": ["name", "price", "categoryId", "image", "description", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's role."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was created."
        }
      },
      "required": ["email", "role", "createdAt"]
    }
  },
  "firestore": {
    "/categories/{categoryId}": {
      "schema": {
        "$ref": "#/entities/Category"
      },
      "description": "Stores all categories."
    },
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Stores all products."
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles and roles."
    }
  }
}
